<Window x:Class="KeresztrejtvenyGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Keresztrejtvény készítő" Height="600" Width="800">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <Label Content="Sorok:"/>
            <ComboBox x:Name="cbSorok" Width="50" Margin="5"/>
            <Label Content="Oszlopok:"/>
            <ComboBox x:Name="cbOszlopok" Width="50" Margin="5"/>
            <Button x:Name="btnLetrehozas" Content="Keresztrejtvény létrehozása"  Padding="5,0" Click="btnLetrehozas_Click"/>

            <Separator Width="20" Background="Transparent"/>

            <Button x:Name="btnMentes" Content="Mentés"  Padding="5,0"/>
            <ComboBox x:Name="cbMentesIndex" Width="50" Margin="5"/>
        </StackPanel>

        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="icRacs">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid x:Name="ugRacs" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>